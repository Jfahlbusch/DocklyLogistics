# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_TENANT=demo

# Database
DATABASE_URL=postgresql://docklylogistics:docklylogistics@localhost:5432/docklylogistics?schema=docklylogistics

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-long-random

# Keycloak (BackOfficeDigital)
KEYCLOAK_URL=https://login.backofficedigital.de/auth
KEYCLOAK_REALM=backofficedigital
KEYCLOAK_CLIENT_ID=docklylogistics
KEYCLOAK_CLIENT_SECRET=change-me
KEYCLOAK_ISSUER=https://login.backofficedigital.de/auth/realms/backofficedigital

# Keycloak Admin (für interne Freigabe)
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_CLIENT_SECRET=change-me

# Logging
LOG_LEVEL=info
