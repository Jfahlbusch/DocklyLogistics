generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  GLOBAL_ADMIN
  MANAGER
  USER
  VIEWER
}

model Tenant {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  @@index([name])
}

model User {
  id                      String    @id @default(cuid())
  email                   String
  name                    String?
  keycloakSub             String?   @unique
  role                    UserRole  @default(VIEWER)
  tenantId                String

  internalApprovalAt      DateTime?
  internalApprovalBy      String?
  internalApprovalComment String?

  lastLoginAt             DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([role])
}

enum SupplierChannel {
  EMAIL
  API
  EDI
}

enum BarcodeSource {
  SKU
  EAN
}

enum UnitKind {
  PIECE
  KG
  G
  L
  ML
  PACK
  SACK
  BOX
  PALLET
  OTHER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  SEND
  CANCEL
  RECEIVE
  LOGIN
  EXPORT
}

model Article {
  id                String   @id @default(cuid())
  tenantId          String
  sku               String
  name              String
  shortDesc         String?
  longDesc          String?
  category          String?
  eanGtin           String?
  baseUnit          UnitKind
  orderUnit         UnitKind
  packFactor        Int      // Basiseinheiten pro Bestelleinheit
  barcodeSource     BarcodeSource @default(SKU)
  minStock          Int      @default(0)
  defaultLocationId String?
  vatRate           Decimal? @db.Decimal(5,2)
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  suppliers         ArticleSupplier[]
  defaultLocation   StorageLocation? @relation(fields: [defaultLocationId], references: [id])
  balances          StockBalance[]
  movements         StockMovement[]
  suggestions       OrderSuggestion[]
  orderItems        OrderItem[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, eanGtin])
}

model Supplier {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  contactName   String?
  email         String?
  phone         String?
  street        String?
  city          String?
  postalCode    String?
  country       String?
  channel       SupplierChannel @default(EMAIL)
  channelConfig Json     // Empfänger-seitig (an wen wird verschickt)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  articles      ArticleSupplier[]
  suggestions   OrderSuggestion[]
  orders        Order[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model ArticleSupplier {
  id             String  @id @default(cuid())
  articleId      String
  supplierId     String
  purchasePrice  Decimal @db.Decimal(12,4)
  currency       String  @default("EUR")
  isPrimary      Boolean @default(false)
  leadTimeDays   Int     @default(3)
  minOrderQty    Int     @default(1)
  supplierSku    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  article  Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([articleId, supplierId])
  @@index([supplierId])
}

model StorageLocation {
  id        String   @id @default(cuid())
  tenantId  String
  code      String   // z.B. A-02-3
  name      String
  zone      String?
  bin       String?
  capacity  Int?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  articles  Article[]
  balances  StockBalance[]
  movements StockMovement[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model TenantChannelConfig {
  id        String   @id @default(cuid())
  tenantId  String
  channel   SupplierChannel
  active    Boolean  @default(true)
  isDefault Boolean  @default(false)
  label     String?  // freier Name, z.B. "Hauptmailbox"
  config    Json     // schema-validiert je Kanal (Zod-validiert in der API-Schicht)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, channel, label])
  @@index([tenantId, channel])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  entity     String   // "Article", "Supplier", ...
  entityId   String
  action     AuditAction
  actorId    String
  actorEmail String
  ip         String?
  userAgent  String?
  before     Json?
  after      Json?
  hash       String   @default("")       // Hash-Chain kommt M6, in M2 leerer Stub
  prevHash   String   @default("")
  createdAt  DateTime @default(now())

  @@index([tenantId, entity, entityId])
  @@index([createdAt])
}

model StockBalance {
  id            String    @id @default(cuid())
  tenantId      String
  articleId     String
  locationId    String
  quantity      Int       @default(0)
  lastCountedAt DateTime?
  updatedAt     DateTime  @updatedAt
  createdAt     DateTime  @default(now())

  article  Article         @relation(fields: [articleId], references: [id], onDelete: Cascade)
  location StorageLocation @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@unique([articleId, locationId])
  @@index([tenantId])
  @@index([tenantId, articleId])
}

model StockMovement {
  id         String   @id @default(cuid())
  tenantId   String
  articleId  String
  locationId String
  delta      Int
  reason     String
  refType    String?
  refId      String?
  note       String?
  createdBy  String
  createdAt  DateTime @default(now())

  article  Article         @relation(fields: [articleId], references: [id])
  location StorageLocation @relation(fields: [locationId], references: [id])

  @@index([tenantId, articleId, createdAt])
  @@index([tenantId, locationId, createdAt])
}

model OrderSuggestion {
  id           String   @id @default(cuid())
  tenantId     String
  articleId    String
  supplierId   String?
  qtyOrderUnit Int
  reason       String   // AUTO_MIN_STOCK | MANUAL_SCAN
  status       String   @default("PENDING") // PENDING | CONFIRMED | DISMISSED
  note         String?
  createdBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  article  Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  supplier Supplier? @relation(fields: [supplierId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, articleId])
}

enum OrderStatus {
  DRAFT
  REVIEW
  APPROVED
  SENT
  CONFIRMED
  PARTIALLY_RECEIVED
  RECEIVED
  CLOSED
  CANCELLED
}

model Order {
  id          String      @id @default(cuid())
  tenantId    String
  orderNo     String      @unique
  supplierId  String
  status      OrderStatus @default(DRAFT)
  currency    String      @default("EUR")
  total       Decimal     @db.Decimal(14,2) @default(0)
  notes       String?
  createdBy   String
  sentAt      DateTime?
  confirmedAt DateTime?
  cancelledAt DateTime?
  closedAt    DateTime?
  pdfPath     String?
  pdfHash     String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  supplier Supplier     @relation(fields: [supplierId], references: [id])
  items    OrderItem[]
  events   OrderEvent[]

  @@index([tenantId, status])
  @@index([supplierId])
  @@index([tenantId, createdAt])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  articleId    String
  qtyOrderUnit Int
  qtyBase      Int
  unitPrice    Decimal  @db.Decimal(12,4)
  lineTotal    Decimal  @db.Decimal(14,2)
  qtyReceived  Int      @default(0)
  createdAt    DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id])

  @@index([orderId])
}

model OrderEvent {
  id         String       @id @default(cuid())
  orderId    String
  type       String       // CREATED | STATUS_CHANGED | NOTE | SEND | CANCEL | RECEIVE | WEBHOOK | UPDATE
  fromStatus OrderStatus?
  toStatus   OrderStatus?
  actorId    String
  actorEmail String
  ip         String?
  userAgent  String?
  payload    Json
  hash       String       @default("")
  prevHash   String       @default("")
  createdAt  DateTime     @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}
