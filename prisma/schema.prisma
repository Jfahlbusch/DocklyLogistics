generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  GLOBAL_ADMIN
  MANAGER
  USER
  VIEWER
}

model Tenant {
  id               String   @id @default(cuid())
  name             String   @unique
  featureProfileId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users          User[]
  featureProfile FeatureProfile? @relation(fields: [featureProfileId], references: [id], onDelete: SetNull)

  @@index([name])
}

// Per-tenant branding for the order-slip PDF (Briefkopf/Brieffuß) — edited
// graphically under Settings, not by hand. One row per tenant.
model TenantPdfSettings {
  tenantId    String   @id
  logoDataUri String?  @db.Text // Briefkopf-Logo als data:-URI (Upload)
  headerText  String?           // Briefkopf-Zusatz (z.B. Adresse, Slogan)
  footerText  String?           // Brieffuß (z.B. Bankdaten, USt-IdNr.)
  updatedAt   DateTime @updatedAt
}

// Feature permissions resolved against lib/features.ts. enabled true=grant,
// false=deny; an absent row falls back to the feature's built-in default.
// Per-role defaults (MANAGER/USER/VIEWER) + per-user overrides.
model RoleFeature {
  tenantId   String
  role       UserRole
  featureKey String
  enabled    Boolean
  updatedAt  DateTime @updatedAt

  @@id([tenantId, role, featureKey])
  @@index([tenantId, role])
}

model UserFeatureOverride {
  tenantId   String
  userId     String
  featureKey String
  enabled    Boolean
  updatedAt  DateTime @updatedAt

  @@id([tenantId, userId, featureKey])
  @@index([tenantId, userId])
}

model User {
  id                      String    @id @default(cuid())
  email                   String
  name                    String?
  keycloakSub             String?   @unique
  role                    UserRole  @default(VIEWER)
  tenantId                String

  internalApprovalAt      DateTime?
  internalApprovalBy      String?
  internalApprovalComment String?

  lastLoginAt             DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([role])
}

enum SupplierChannel {
  EMAIL
  API
  EDI
}

enum BarcodeSource {
  SKU
  EAN
}

enum UnitKind {
  PIECE
  KG
  G
  L
  ML
  PACK
  SACK
  BOX
  PALLET
  OTHER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  SEND
  CANCEL
  RECEIVE
  LOGIN
  EXPORT
}

model Article {
  id                String   @id @default(cuid())
  tenantId          String
  sku               String
  name              String
  shortDesc         String?
  longDesc          String?
  category          String?
  eanGtin           String?
  baseUnit          UnitKind
  orderUnit         UnitKind
  packFactor        Int      // Basiseinheiten pro Bestelleinheit
  barcodeSource     BarcodeSource @default(SKU)
  minStock          Int      @default(0)
  defaultLocationId String?
  vatRate           Decimal? @db.Decimal(5,2)
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  suppliers         ArticleSupplier[]
  defaultLocation   StorageLocation? @relation(fields: [defaultLocationId], references: [id])
  balances          StockBalance[]
  movements         StockMovement[]
  suggestions       OrderSuggestion[]
  orderItems        OrderItem[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, eanGtin])
}

model Supplier {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  contactName   String?
  email         String?
  phone         String?
  street        String?
  city          String?
  postalCode    String?
  country       String?
  channel       SupplierChannel @default(EMAIL)
  channelConfig Json     // Empfänger-seitig (an wen wird verschickt)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  articles      ArticleSupplier[]
  suggestions   OrderSuggestion[]
  orders        Order[]
  apiKeys       SupplierApiKey[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model ArticleSupplier {
  id             String  @id @default(cuid())
  articleId      String
  supplierId     String
  purchasePrice  Decimal @db.Decimal(12,4)
  currency       String  @default("EUR")
  isPrimary      Boolean @default(false)
  leadTimeDays   Int     @default(3)
  minOrderQty    Int     @default(1)
  supplierSku    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  article  Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([articleId, supplierId])
  @@index([supplierId])
}

model StorageLocation {
  id        String   @id @default(cuid())
  tenantId  String
  code      String   // z.B. A-02-3
  name      String
  zone      String?
  bin       String?
  capacity  Int?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  articles  Article[]
  balances  StockBalance[]
  movements StockMovement[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model TenantChannelConfig {
  id        String   @id @default(cuid())
  tenantId  String
  channel   SupplierChannel
  active    Boolean  @default(true)
  isDefault Boolean  @default(false)
  label     String?  // freier Name, z.B. "Hauptmailbox"
  config    Json     // schema-validiert je Kanal (Zod-validiert in der API-Schicht)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, channel, label])
  @@index([tenantId, channel])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  entity     String   // "Article", "Supplier", ...
  entityId   String
  action     AuditAction
  actorId    String
  actorEmail String
  ip         String?
  userAgent  String?
  before     Json?
  after      Json?
  hash       String   @default("")       // Hash-Chain kommt M6, in M2 leerer Stub
  prevHash   String   @default("")
  createdAt  DateTime @default(now())

  @@index([tenantId, entity, entityId])
  @@index([createdAt])
}

model StockBalance {
  id            String    @id @default(cuid())
  tenantId      String
  articleId     String
  locationId    String
  quantity      Int       @default(0)
  lastCountedAt DateTime?
  updatedAt     DateTime  @updatedAt
  createdAt     DateTime  @default(now())

  article  Article         @relation(fields: [articleId], references: [id], onDelete: Cascade)
  location StorageLocation @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@unique([articleId, locationId])
  @@index([tenantId])
  @@index([tenantId, articleId])
}

model StockMovement {
  id         String   @id @default(cuid())
  tenantId   String
  articleId  String
  locationId String
  delta      Int
  reason     String
  refType    String?
  refId      String?
  note       String?
  createdBy  String
  createdAt  DateTime @default(now())

  article  Article         @relation(fields: [articleId], references: [id])
  location StorageLocation @relation(fields: [locationId], references: [id])

  @@index([tenantId, articleId, createdAt])
  @@index([tenantId, locationId, createdAt])
}

model OrderSuggestion {
  id           String   @id @default(cuid())
  tenantId     String
  articleId    String
  supplierId   String?
  qtyOrderUnit Int
  reason       String   // AUTO_MIN_STOCK | MANUAL_SCAN
  status       String   @default("PENDING") // PENDING | CONFIRMED | DISMISSED
  note         String?
  createdBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  article  Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  supplier Supplier? @relation(fields: [supplierId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, articleId])
}

enum OrderStatus {
  DRAFT
  REVIEW
  APPROVED
  SENT
  CONFIRMED
  PARTIALLY_RECEIVED
  RECEIVED
  CLOSED
  CANCELLED
}

model Order {
  id          String      @id @default(cuid())
  tenantId    String
  orderNo     String      @unique
  supplierId  String
  status      OrderStatus @default(DRAFT)
  currency    String      @default("EUR")
  total       Decimal     @db.Decimal(14,2) @default(0)
  notes       String?
  createdBy   String
  sentAt      DateTime?
  confirmedAt DateTime?
  cancelledAt DateTime?
  closedAt    DateTime?
  pdfPath     String?
  pdfHash     String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  supplier Supplier     @relation(fields: [supplierId], references: [id])
  items    OrderItem[]
  events   OrderEvent[]

  @@index([tenantId, status])
  @@index([supplierId])
  @@index([tenantId, createdAt])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  articleId    String
  qtyOrderUnit Int
  qtyBase      Int
  unitPrice    Decimal  @db.Decimal(12,4)
  lineTotal    Decimal  @db.Decimal(14,2)
  qtyReceived  Int      @default(0)
  createdAt    DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id])

  @@index([orderId])
}

model OrderEvent {
  id         String       @id @default(cuid())
  orderId    String
  type       String       // CREATED | STATUS_CHANGED | NOTE | SEND | CANCEL | RECEIVE | WEBHOOK | UPDATE
  fromStatus OrderStatus?
  toStatus   OrderStatus?
  actorId    String
  actorEmail String
  ip         String?
  userAgent  String?
  payload    Json
  hash       String       @default("")
  prevHash   String       @default("")
  createdAt  DateTime     @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model SupplierApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  supplierId String
  label      String?
  prefix     String    @unique
  hash       String
  scopes     String[]
  lastUsedAt DateTime?
  revokedAt  DateTime?
  expiresAt  DateTime?
  createdBy  String
  createdAt  DateTime  @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([tenantId, supplierId])
  @@index([prefix])
}

/// Personal API key for a user. The key's permissions are a snapshot of the
/// user's role at creation time (role lives in Keycloak claims, not User.role),
/// scoped to the user's tenant. Revoke via revokedAt.
model UserApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  userId     String
  userEmail  String
  label      String?
  prefix     String    @unique
  hash       String
  role       UserRole
  lastUsedAt DateTime?
  revokedAt  DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId, userId])
  @@index([prefix])
}

/// Tenant-wide in-app notification (ops events: webhook failures, …). Shared per
/// tenant; readAt marks it read for the team. Surfaced in the header bell.
model Notification {
  id        String    @id @default(cuid())
  tenantId  String
  type      String
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([tenantId, readAt, createdAt])
}

model Webhook {
  id              String   @id @default(cuid())
  tenantId        String
  url             String
  events          String[]
  active          Boolean  @default(true)
  secretEncrypted String
  description     String?
  lastDeliveredAt DateTime?
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  deliveries WebhookDelivery[]

  @@index([tenantId, active])
}

model WebhookDelivery {
  id             String   @id @default(cuid())
  tenantId       String
  webhookId      String
  event          String
  payload        Json
  status         String   @default("PENDING")
  attempts       Int      @default(0)
  lastStatusCode Int?
  lastError      String?
  nextAttemptAt  DateTime @default(now())
  succeededAt    DateTime?
  givenUpAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
  @@index([tenantId, webhookId])
}

model AuditSeal {
  id         String   @id @default(cuid())
  tenantId   String
  sealDate   String   // YYYY-MM-DD (UTC)
  rootHash   String
  entryCount Int
  sealedAt   DateTime @default(now())

  @@unique([tenantId, sealDate])
  @@index([tenantId, sealDate])
}

/// Per-tenant EDI settings: the inbound mailbox (partners POST EDIFACT to
/// /api/edi/inbound/{inboundToken}) and processing flags. The tenant's own
/// EDI identity (GLN/qualifier) lives in TenantChannelConfig(channel=EDI).
model TenantEdiSettings {
  tenantId      String   @id
  inboundToken  String   @unique
  inboundActive Boolean  @default(true)
  autoConfirm   Boolean  @default(true) // inbound ORDRSP auto-confirms the referenced order
  // AS2 identity (generated on demand): private key AES-encrypted via APP_KEY.
  as2Id                  String?  @unique
  as2PrivateKeyEncrypted String?  @db.Text
  as2CertificatePem      String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// EDI message archive/monitor — every EDIFACT interchange in or out.
/// Loose references (no FK) to supplier/order, like AuditLog.
model EdiMessage {
  id             String   @id @default(cuid())
  tenantId       String
  direction      String   // IN | OUT
  type           String   // ORDERS | ORDRSP | UNKNOWN
  status         String   // RECEIVED | PROCESSED | FAILED | SENT | SEND_FAILED
  transport      String?  // http | file | inbound
  supplierId     String?
  orderId        String?
  interchangeRef String?
  documentNo     String?  // BGM document number (e.g. order no)
  payload        String   @db.Text
  parsed         Json?
  error          String?
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, createdAt])
  @@index([tenantId, direction, status])
  @@index([tenantId, orderId])
}

/// Operator-level feature set (GLOBAL_ADMIN only): a named template of
/// featureKey→enabled that can be assigned to tenants. Resolution per tenant:
/// TenantFeature override ?? profile.features[key] ?? true (everything on).
model FeatureProfile {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  features    Json     // Record<featureKey, boolean>
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenants Tenant[]
}

/// Per-tenant feature override set by the operator (GLOBAL_ADMIN). A `false`
/// here hard-disables the feature for every user of the tenant, regardless of
/// role defaults or user overrides.
model TenantFeature {
  tenantId   String
  featureKey String
  enabled    Boolean
  updatedAt  DateTime @updatedAt

  @@id([tenantId, featureKey])
  @@index([tenantId])
}

/// Per-partner EDI mailbox: each partner gets their own inbound token
/// (individually revocable/rotatable). Optional binding: `supplierId` limits
/// ORDRSP processing to that supplier's orders; `partnerGln` validates the
/// UNB sender. The tenant-wide mailbox (TenantEdiSettings) stays as fallback.
model EdiPartnerMailbox {
  id         String    @id @default(cuid())
  tenantId   String
  name       String
  partnerGln String?
  supplierId String?
  token      String    @unique // "edi_p_<hex>"
  // AS2 partner data: their AS2-ID, their public certificate, their endpoint.
  as2Id             String?
  as2CertificatePem String? @db.Text
  as2Url            String?
  active     Boolean   @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

/// Replay protection for AS2: one row per (tenant, AS2 Message-ID). The unique
/// constraint is the atomic dedupe — a second delivery with the same Message-ID
/// is answered with a duplicate-document MDN and NOT reprocessed.
model As2InboundReceipt {
  id        String   @id @default(cuid())
  tenantId  String
  messageId String
  createdAt DateTime @default(now())

  @@unique([tenantId, messageId])
  @@index([tenantId])
}
